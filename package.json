{
  "name": "nebular-news",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "check:guardrails": "node scripts/check-no-global-reload.mjs",
    "check:first-party-config": "node scripts/check-no-first-party-config.mjs",
    "check:ssr-render-inner": "node scripts/check-ssr-render-inner.mjs",
    "check:worker-scheduled": "node scripts/check-scheduled-export.mjs",
    "build": "npm run check:guardrails && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:pull": "playwright test e2e/manual-pull-status.spec.ts",
    "hash-password": "node scripts/hash-password.mjs",
    "scheduler:apply:staging": "node scripts/apply-scheduler-cron.mjs --env staging",
    "scheduler:apply:prod": "node scripts/apply-scheduler-cron.mjs --env production",
    "render:wrangler": "node scripts/render-wrangler-config.mjs",
    "migrate:staging": "node scripts/run-remote-migration.mjs --env staging",
    "migrate:prod": "node scripts/run-remote-migration.mjs --env production",
    "deploy:staging": "npm run build && wrangler deploy --env staging --config ${WRANGLER_CONFIG_PATH:-wrangler.toml}",
    "deploy:prod": "npm run build && wrangler deploy --env production --config ${WRANGLER_CONFIG_PATH:-wrangler.toml}"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@mozilla/readability": "0.5.0",
    "@sveltejs/adapter-vercel": "^5.10.3",
    "@sveltejs/kit": "2.12.2",
    "@tabler/icons-svelte": "^3.36.1",
    "cookie": "0.6.0",
    "fast-xml-parser": "4.4.1",
    "jose": "^6.2.2",
    "linkedom": "0.16.11",
    "luxon": "^3.7.2",
    "nanoid": "5.0.7",
    "postgres": "^3.4.8",
    "svelte": "5.53.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "4.0.3",
    "@testing-library/svelte": "^5.3.1",
    "@types/cookie": "0.6.0",
    "@types/node": "^25.5.0",
    "jsdom": "^28.0.0",
    "svelte-check": "3.8.6",
    "typescript": "5.6.3",
    "vite": "5.4.10",
    "vitest": "2.1.2",
    "wrangler": "^4.63.0"
  }
}
